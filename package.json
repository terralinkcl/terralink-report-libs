{
  "name": "terralink-report-libs",
  "version": "1.0.0",
  "description": "Libreria compartida de formatos PDF de informes Terralink (linea editorial: portada, indice, secciones)",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "fonts"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "@react-pdf/renderer": ">=3.0.0"
  },
  "devDependencies": {
    "@types/node": "20.19.37",
    "@types/react": "19.1.2",
    "react": "19.2.4",
    "@react-pdf/renderer": "4.3.2",
    "tsup": "8.5.0",
    "typescript": "5.9.3"
  }
}
